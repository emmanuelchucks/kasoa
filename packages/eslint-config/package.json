{
  "name": "@kasoa/eslint-config",
  "version": "0.0.30",
  "description": "Kasoa's ESLint config",
  "keywords": [
    "eslint",
    "eslintconfig",
    "kasoa"
  ],
  "homepage": "https://github.com/emmanuelchucks/kasoa/tree/main/packages/eslint-config",
  "bugs": {
    "url": "https://github.com/emmanuelchucks/kasoa/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Emmanuel Chucks",
    "email": "hi@emmanuelchucks.com",
    "url": "https://emmanuelchucks.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emmanuelchucks/kasoa.git",
    "directory": "packages/eslint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./base": {
      "types": "./dist/src/base/index.d.mts",
      "import": "./dist/src/base/index.mjs"
    },
    "./node": {
      "types": "./dist/src/node/index.d.mts",
      "import": "./dist/src/node/index.mjs"
    },
    "./react": {
      "types": "./dist/src/react/index.d.mts",
      "import": "./dist/src/react/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^10.1.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-lite": "0.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-jsx-a11y-x": "^0.1.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn-x": "^3.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@kasoa/vite-plus-config": "workspace:*",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
    "prettier": "^3.8.1",
    "vite-plus": "^0.1.14"
  },
  "peerDependencies": {
    "eslint": ">=9.35.0 <11"
  },
  "engines": {
    "node": ">=24"
  }
}
