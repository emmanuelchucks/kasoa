{
  "name": "@kasoa/oxlint-config",
  "version": "0.0.11",
  "description": "Kasoa's Oxlint configurations",
  "keywords": [
    "kasoa",
    "linter",
    "oxlint"
  ],
  "homepage": "https://github.com/emmanuelchucks/kasoa/tree/main/packages/oxlint-config",
  "bugs": {
    "url": "https://github.com/emmanuelchucks/kasoa/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Emmanuel Chucks",
    "email": "hi@emmanuelchucks.com",
    "url": "https://emmanuelchucks.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emmanuelchucks/kasoa.git",
    "directory": "packages/oxlint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./base": {
      "types": "./dist/src/base/index.d.mts",
      "import": "./dist/src/base/index.mjs"
    },
    "./server": {
      "types": "./dist/src/server/index.d.mts",
      "import": "./dist/src/server/index.mjs"
    },
    "./react": {
      "types": "./dist/src/react/index.d.mts",
      "import": "./dist/src/react/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@kasoa/vite-plus-config": "workspace:*",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
    "vite-plus": "^0.1.14"
  },
  "peerDependencies": {
    "oxlint": ">=1.51.0 <2",
    "oxlint-tsgolint": ">=0.16.0 <1"
  },
  "engines": {
    "node": ">=24"
  }
}
